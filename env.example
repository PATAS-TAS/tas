# Prefer PATAS-specific key if set; otherwise fallback to OPENAI_API_KEY
PATAS_OPENAI_API_KEY=
OPENAI_API_KEY=
MODEL_NAME=unitary/multilingual-toxic-xlm-roberta

RULES_THRESHOLD=0.65
ML_THRESHOLD=0.8
LLM_FALLBACK=true

# Classification decision threshold (spam_score >= threshold => spam)
DECISION_THRESHOLD=0.35

CACHE_SIZE=10000
CACHE_TTL=3600

# LLM cache (reduces latency and cost)
LLM_CACHE_SIZE=5000
LLM_CACHE_TTL=86400
